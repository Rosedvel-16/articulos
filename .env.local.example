# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# https://serpapi.com/manage-api-key
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face — imágenes de cabecera (tier gratis, sin tarjeta)
# Token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default gratis: SDXL + provider hf-inference (no hace falta Billing/tarjeta)
# HUGGINGFACE_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# HUGGINGFACE_PROVIDER=hf-inference

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase → Project Settings → API → service_role (secret, solo servidor)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del sitio (local o Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
