# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# https://serpapi.com/manage-api-key
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face — imágenes de cabecera del blog
# Token: https://huggingface.co/settings/tokens
# Debe ser fine-grained o classic con permiso "Make calls to Inference Providers"
# Además necesitas créditos en https://huggingface.co/settings/billing
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional (default: black-forest-labs/FLUX.1-schnell)
# HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Opcional: auto | fal-ai | replicate | hf-inference
# HUGGINGFACE_PROVIDER=auto

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase → Project Settings → API → service_role (secret, solo servidor)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del sitio (local o Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
